<section class="jb-section jb-product" data-section-id="{{ section.id }}">
  <div class="jb-container jb-product__inner">
    <div class="jb-product__media">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          srcset="{{ product.featured_image | image_url: width: 500 }} 500w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
          sizes="(min-width: 900px) 540px, 100vw"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="540"
          height="540"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        <div class="jb-product__placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <div class="jb-product__info">
      {%- if product.compare_at_price > product.price -%}
        {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
        {%- render 'badge-sale', discount: discount_pct -%}
      {%- endif -%}

      <h1 class="jb-product__title">{{ product.title }}</h1>

      <div class="jb-product__price">
        {%- if product.compare_at_price > product.price -%}
          <span class="jb-product__price-sale">{{ product.price | money }}</span>
          <span class="jb-product__price-compare">{{ product.compare_at_price | money }}</span>
        {%- else -%}
          <span class="jb-product__price-sale">{{ product.price | money }}</span>
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div class="jb-product__description">{{ product.description }}</div>
      {%- endif -%}

      {%- form 'product', product, class: 'jb-product__form', id: 'product-form' -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="jb-field">
              <label for="Option{{ forloop.index }}">{{ option.name }}</label>
              <select id="Option{{ forloop.index }}" name="options[{{ option.name | escape }}]" data-jb-variant-select>
                {%- for value in option.values -%}
                  <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                    {{ value }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-jb-variant-id>

        <div class="jb-field">
          <label for="Quantity">Cantidad</label>
          <input type="number" id="Quantity" name="quantity" value="1" min="1" inputmode="numeric">
        </div>

        <button
          type="submit"
          name="add"
          class="jb-btn jb-btn--primary jb-btn--lg jb-btn--block"
          {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
        >
          {%- if product.selected_or_first_available_variant.available -%}
            Agregar al carrito
          {%- else -%}
            Agotado
          {%- endif -%}
        </button>
      {%- endform -%}

      <div class="jb-product__trust">
        <ul role="list">
          <li>
            <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 8.5L6 11.5L13 4.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Entrega activada en 24-72 horas hábiles
          </li>
          <li>
            <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 8.5L6 11.5L13 4.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Reposición caso por caso de leads malos
          </li>
          <li>
            <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 8.5L6 11.5L13 4.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Soporte por WhatsApp antes y después de la compra
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Producto principal",
  "settings": []
}
{% endschema %}
