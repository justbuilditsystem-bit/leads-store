<section class="jb-section jb-product" data-section-id="{{ section.id }}">
  <div class="jb-container jb-product__inner">
    <div class="jb-product__media">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          srcset="{{ product.featured_image | image_url: width: 500 }} 500w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
          sizes="(min-width: 900px) 540px, 100vw"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="540"
          height="540"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        <div class="jb-product__placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <div class="jb-product__info">
      {%- if product.compare_at_price > product.price -%}
        {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
        {%- render 'badge-sale', discount: discount_pct -%}
      {%- endif -%}

      <h1 class="jb-product__title">{{ product.title }}</h1>

      <div class="jb-product__price">
        {%- if product.compare_at_price > product.price -%}
          <span class="jb-product__price-sale">{{ product.price | money }}</span>
          <span class="jb-product__price-compare">{{ product.compare_at_price | money }}</span>
        {%- else -%}
          <span class="jb-product__price-sale">{{ product.price | money }}</span>
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div class="jb-product__description">{{ product.description }}</div>
      {%- endif -%}

      {%- form 'product', product, class: 'jb-product__form', id: 'product-form' -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="jb-field">
              <label for="Option{{ forloop.index }}">{{ option.name }}</label>
              <select id="Option{{ forloop.index }}" name="options[{{ option.name | escape }}]" data-jb-variant-select>
                {%- for value in option.values -%}
                  <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                    {{ value }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-jb-variant-id>
        {%- assign product_title_downcase = product.title | downcase -%}
{%- assign is_leads_product = false -%}
{%- if product_title_downcase contains 'lead' -%}
  {%- assign is_leads_product = true -%}
{%- endif -%}

<div class="jb-product-intake" data-product-intake>
  <h3 class="jb-product-intake__title">Completa tus datos antes de continuar</h3>

  <div class="jb-product-intake__notice">
    ⚠️ Las órdenes pueden iniciar en un plazo de hasta <strong>72 horas hábiles</strong> después de realizada la compra.
  </div>

  <input type="hidden" name="properties[Producto solicitado]" value="{{ product.title | escape }}">

  <div class="jb-product-intake__grid">
    <div class="jb-field">
      <label for="BuyerName">Nombre completo</label>
      <input type="text" id="BuyerName" name="properties[Nombre completo]" required>
    </div>

    <div class="jb-field">
      <label for="BuyerEmail">Correo electrónico</label>
      <input type="email" id="BuyerEmail" name="properties[Correo electrónico]" autocomplete="email" required>
    </div>

    <div class="jb-field jb-product-intake__full">
      <label for="BuyerPhone">Teléfono / WhatsApp</label>
      <input type="tel" id="BuyerPhone" name="properties[Teléfono / WhatsApp]" autocomplete="tel" required>
    </div>
  </div>

  {%- if is_leads_product -%}
    <div class="jb-field jb-product-intake__full">
      <label>Selecciona los estados</label>

      <div class="jb-product-intake__info">
        ℹ️ Debes seleccionar <strong>mínimo 3 estados</strong> para continuar.
      </div>

      <input type="hidden" id="LeadStates" name="properties[Estados seleccionados]" value="">

      <div class="jb-states-actions">
        <button type="button" class="jb-mini-btn" data-select-all-states>Seleccionar todos</button>
        <button type="button" class="jb-mini-btn" data-clear-all-states>Borrar todos</button>
      </div>

      <div class="jb-states-grid" data-states-list>
        {%- assign states = "Alabama,Alaska,Arizona,Arkansas,California,Colorado,Connecticut,Delaware,Florida,Georgia,Hawaii,Idaho,Illinois,Indiana,Iowa,Kansas,Kentucky,Louisiana,Maine,Maryland,Massachusetts,Michigan,Minnesota,Mississippi,Missouri,Montana,Nebraska,Nevada,New Hampshire,New Jersey,New Mexico,New York,North Carolina,North Dakota,Ohio,Oklahoma,Oregon,Pennsylvania,Rhode Island,South Carolina,South Dakota,Tennessee,Texas,Utah,Vermont,Virginia,Washington,West Virginia,Wisconsin,Wyoming" | split: "," -%}
        {%- for state in states -%}
          <label class="jb-state-option">
            <input type="checkbox" value="{{ state | strip }}" data-state-checkbox>
            <span>{{ state | strip }}</span>
          </label>
        {%- endfor -%}
      </div>

      <p class="jb-product-intake__error" data-states-error hidden>
        Debes seleccionar mínimo 3 estados para continuar.
      </p>
    </div>
  {%- endif -%}

  <div class="jb-product-intake__row">
    <div class="jb-field">
      <label>¿Ya compraste leads con nosotros?</label>
      <div class="jb-radio-group">
        <label><input type="radio" name="properties[¿Ya compraste leads con nosotros?]" value="Sí" required> Sí</label>
        <label><input type="radio" name="properties[¿Ya compraste leads con nosotros?]" value="No" required> No</label>
      </div>
    </div>

    <div class="jb-field">
      <label>¿Cuándo te gustaría comenzar?</label>
      <div class="jb-radio-group">
        <label><input type="radio" name="properties[Inicio deseado]" value="Inmediatamente" required> Inmediatamente</label>
        <label><input type="radio" name="properties[Inicio deseado]" value="Luego" required> Luego</label>
      </div>
    </div>
  </div>

  <div class="jb-field">
    <label>¿Cuentas con un CRM externo de GHL?</label>
    <div class="jb-radio-group">
      <label><input type="radio" name="properties[¿Cuenta con CRM externo de GHL?]" value="Sí" required> Sí</label>
      <label><input type="radio" name="properties[¿Cuenta con CRM externo de GHL?]" value="No" required> No</label>
    </div>
  </div>

  <div class="jb-field">
    <label for="BuyerNotes">Notas adicionales</label>
    <textarea id="BuyerNotes" name="properties[Notas adicionales]" rows="3" placeholder="Ej: horario de contacto, detalles del negocio, preferencias, etc."></textarea>
  </div>
</div>

        <div class="jb-field">
          <label for="Quantity">Cantidad</label>
          <input type="number" id="Quantity" name="quantity" value="1" min="1" inputmode="numeric">
        </div>

        <button
          type="submit"
          name="add"
          class="jb-btn jb-btn--primary jb-btn--lg jb-btn--block"
          {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
        >
          {%- if product.selected_or_first_available_variant.available -%}
            Agregar al carrito
          {%- else -%}
            Agotado
          {%- endif -%}
        </button>
      {%- endform -%}

      <div class="jb-product__trust">
        <ul role="list">
          <li>
            <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 8.5L6 11.5L13 4.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Entrega activada en 24-72 horas hábiles
          </li>
          <li>
            <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 8.5L6 11.5L13 4.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Reposición caso por caso de leads malos
          </li>
          <li>
            <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 8.5L6 11.5L13 4.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Soporte por WhatsApp antes y después de la compra
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Producto principal",
  "settings": []
}
{% endschema %}
