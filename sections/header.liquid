<header class="jb-header">
  <div class="jb-container jb-header__inner">
    <a href="{{ routes.root_url }}" class="jb-header__logo" aria-label="{{ settings.brand_name }} — Inicio">
      {%- if settings.brand_logo != blank -%}
        <img
          src="{{ settings.brand_logo | image_url: width: 400 }}"
          srcset="{{ settings.brand_logo | image_url: width: 200 }} 1x, {{ settings.brand_logo | image_url: width: 400 }} 2x"
          alt="{{ settings.brand_name | escape }}"
          width="{{ settings.logo_max_width }}"
          height="auto"
          loading="eager"
          style="max-width: {{ settings.logo_max_width }}px;"
        >
      {%- else -%}
        <span class="jb-header__logo-text">{{ settings.brand_name }}</span>
      {%- endif -%}
    </a>

    <nav class="jb-header__nav" aria-label="Navegación principal">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="jb-header__link {% if link.active %}is-active{% endif %}">
          {{- link.title -}}
        </a>
      {%- endfor -%}
    </nav>

    <div class="jb-header__actions">
      <a href="{{ routes.cart_url }}" class="jb-header__cart" aria-label="Ver carrito">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 7h13"/>
          <circle cx="9" cy="20" r="1.5"/>
          <circle cx="18" cy="20" r="1.5"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="jb-header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <button class="jb-header__menu-btn" aria-label="Abrir menú" aria-expanded="false" data-jb-menu-toggle>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="jb-header__mobile-nav" id="jb-mobile-nav" aria-label="Navegación móvil" hidden>
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" class="jb-header__mobile-link">{{ link.title }}</a>
    {%- endfor -%}
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
