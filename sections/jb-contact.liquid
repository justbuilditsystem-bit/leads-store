<section class="jb-section jb-contact" data-section-id="{{ section.id }}" id="contacto">
  <div class="jb-container jb-contact__inner">
    <div class="jb-contact__intro">
      <span class="jb-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="jb-section__title">{{ section.settings.title }}</h2>
      <p class="jb-section__subtitle">{{ section.settings.subtitle }}</p>

      <ul class="jb-contact__channels" role="list">
        {%- if settings.whatsapp_url != blank -%}
          <li>
            <a href="{{ settings.whatsapp_url }}" target="_blank" rel="noopener" class="jb-contact__channel">
              <span class="jb-contact__channel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.96L2 22l5.25-1.38a9.94 9.94 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.84 9.84 0 0 0 12.04 2z"/></svg>
              </span>
              <span>WhatsApp directo</span>
            </a>
          </li>
        {%- endif -%}
        {%- if settings.contact_email != blank -%}
          <li>
            <a href="mailto:{{ settings.contact_email }}" class="jb-contact__channel">
              <span class="jb-contact__channel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
              </span>
              <span>{{ settings.contact_email }}</span>
            </a>
          </li>
        {%- endif -%}
      </ul>
    </div>

    <div class="jb-contact__form-wrap">
      {%- form 'contact', class: 'jb-contact__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="jb-contact__success">
            <strong>Mensaje recibido.</strong>
            <p>Te contactamos en menos de 24 horas hábiles. Si es urgente, escribinos por WhatsApp.</p>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="jb-contact__error">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="jb-field">
            <label for="ContactName">Nombre</label>
            <input type="text" id="ContactName" name="contact[name]" required>
          </div>

          <div class="jb-field">
            <label for="ContactEmail">Email</label>
            <input type="email" id="ContactEmail" name="contact[email]" autocomplete="email" required>
          </div>

          <div class="jb-field">
            <label for="ContactPhone">Teléfono / WhatsApp</label>
            <input type="tel" id="ContactPhone" name="contact[phone]" autocomplete="tel">
          </div>

          <div class="jb-field">
            <label for="ContactMessage">¿Qué necesitas?</label>
            <textarea id="ContactMessage" name="contact[body]" rows="4" required></textarea>
          </div>

          <button type="submit" class="jb-btn jb-btn--primary jb-btn--lg jb-btn--block">
            Enviar mensaje
          </button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contacto",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "HABLEMOS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Antes de comprar, hablá con un asesor."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Si es tu primera vez comprando leads o no sabes qué paquete elegir, te orientamos. Sin pitch de venta."
    }
  ],
  "presets": [
    { "name": "Contacto" }
  ]
}
{% endschema %}
