<section class="jb-section jb-hero" data-section-id="{{ section.id }}">
  <div class="jb-container jb-hero__inner">
    <div class="jb-hero__media">
      {%- assign slide_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' and block.settings.image != blank -%}
          {%- assign slide_count = slide_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if slide_count > 0 -%}
        <div class="jb-carousel" data-jb-carousel data-autoplay="{{ section.settings.autoplay_ms | default: 5000 }}">
          <div class="jb-carousel__track">
            {%- for block in section.blocks -%}
              {%- if block.type == 'slide' and block.settings.image != blank -%}
                {%- assign slide_link = block.settings.link | default: '/collections/paquetes' -%}
                <a href="{{ slide_link }}" class="jb-carousel__slide" {{ block.shopify_attributes }}>
                  <img
                    src="{{ block.settings.image | image_url: width: 2000 }}"
                    srcset="{{ block.settings.image | image_url: width: 1000 }} 1000w, {{ block.settings.image | image_url: width: 1600 }} 1600w, {{ block.settings.image | image_url: width: 2000 }} 2000w"
                    sizes="(min-width: 1200px) 1200px, 100vw"
                    alt="{{ block.settings.image.alt | default: block.settings.alt_text | default: 'Slide' | escape }}"
                    width="1600"
                    height="900"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    {% if forloop.first %}fetchpriority="high"{% endif %}
                  >
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if slide_count > 1 -%}
            <button class="jb-carousel__nav jb-carousel__nav--prev" type="button" aria-label="Anterior">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="jb-carousel__nav jb-carousel__nav--next" type="button" aria-label="Siguiente">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <div class="jb-carousel__dots" role="tablist" aria-label="Slides">
              {%- for i in (1..slide_count) -%}
                <button class="jb-carousel__dot {% if forloop.first %}is-active{% endif %}" type="button" data-slide="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}" role="tab"></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="jb-hero__placeholder" aria-hidden="true">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4">
            <rect x="8" y="14" width="48" height="36" rx="3"/>
            <circle cx="22" cy="26" r="3.5"/>
            <path d="M8 44 L24 30 L40 42 L56 28"/>
          </svg>
          <span>Subí aquí las imágenes del carrusel</span>
          <span class="jb-hero__placeholder-hint">Agregá 3 slides desde "Agregar bloque" en el customizer (1600×900px recomendado)</span>
        </div>
      {%- endif -%}
    </div>

    <div class="jb-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="jb-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="jb-hero__title">{{ section.settings.headline }}</h1>
      <p class="jb-hero__subtitle">{{ section.settings.subtitle }}</p>
      <div class="jb-hero__cta">
        {%- if section.settings.cta_primary_text != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="jb-btn jb-btn--primary jb-btn--lg">
            {{ section.settings.cta_primary_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_text != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="jb-btn jb-btn--ghost jb-btn--lg">
            {{ section.settings.cta_secondary_text }}
          </a>
        {%- endif -%}
      </div>
      <ul class="jb-hero__bullets" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'bullet' -%}
            <li class="jb-hero__bullet" {{ block.shopify_attributes }}>
              <span class="jb-hero__bullet-icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 8.5L6 11.5L13 4.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (texto pequeño arriba del título)",
      "default": "PARA AGENTES DE SEGUROS HISPANOS EN USA"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Leads que ya quieren hablar contigo."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Deja de quemar horas en cold calls. Recibe prospectos hispanos que ya levantaron la mano por seguro de vida, IUL o final expense — listos en tu WhatsApp en menos de 72 horas."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Botón primario — texto",
      "default": "Ver paquetes"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Botón primario — URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Botón secundario — texto",
      "default": "Hablar con un asesor"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Botón secundario — URL"
    },
    {
      "type": "header",
      "content": "Carrusel"
    },
    {
      "type": "range",
      "id": "autoplay_ms",
      "label": "Velocidad de rotación (ms)",
      "min": 3000,
      "max": 10000,
      "step": 500,
      "default": 5000
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide del carrusel",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen (1600×900px recomendado)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link al hacer click (default: /collections/paquetes)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Texto alternativo (accesibilidad)"
        }
      ]
    },
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Entrega en 24-72 horas"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "slide", "settings": { "link": "/collections/paquetes", "alt_text": "Paquete Premium de Leads" } },
        { "type": "slide", "settings": { "link": "/collections/paquetes", "alt_text": "No tienes que hacerlo solo" } },
        { "type": "slide", "settings": { "link": "/collections/paquetes", "alt_text": "Crecimiento estratégico y medible" } },
        { "type": "bullet", "settings": { "text": "Entrega en 24-72 horas vía WhatsApp o Facebook Form" } },
        { "type": "bullet", "settings": { "text": "Reposición de leads que vienen mal de origen" } },
        { "type": "bullet", "settings": { "text": "Soporte real antes y después de la compra" } }
      ]
    }
  ]
}
{% endschema %}
