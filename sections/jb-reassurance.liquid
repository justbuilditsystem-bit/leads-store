<section class="jb-section jb-reassurance" data-section-id="{{ section.id }}">
  <div class="jb-container">
    <header class="jb-section__header">
      <span class="jb-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="jb-section__title">{{ section.settings.title }}</h2>
      <p class="jb-section__subtitle">{{ section.settings.subtitle }}</p>
    </header>

    <div class="jb-reassurance__grid">
      {%- for block in section.blocks -%}
        <article class="jb-reassurance__card" {{ block.shopify_attributes }}>
          <div class="jb-reassurance__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'chat' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'bolt' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" stroke-linejoin="round"/></svg>
              {%- when 'refresh' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
            {%- endcase -%}
          </div>
          <h3 class="jb-reassurance__title">{{ block.settings.title }}</h3>
          <p class="jb-reassurance__text">{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reassurance",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "ASÍ TRABAJAMOS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "No estás solo en este proceso."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Si nunca compraste leads o ya te quemaste con otro proveedor, te acompañamos antes y después de la compra para que el dinero rinda."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "options": [
            { "value": "chat", "label": "Chat" },
            { "value": "shield", "label": "Escudo" },
            { "value": "bolt", "label": "Rayo" },
            { "value": "refresh", "label": "Reposición" },
            { "value": "check", "label": "Check" }
          ],
          "default": "chat"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Aclaramos dudas antes de comprar"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "Hablamos por WhatsApp y te decimos qué paquete tiene sentido según tu zona y tu presupuesto. Sin venderte humo."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Reassurance",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "chat",
            "title": "Aclaramos dudas antes de comprar",
            "text": "Hablamos por WhatsApp y te decimos qué paquete tiene sentido según tu zona y tu presupuesto. Sin venderte humo."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "bolt",
            "title": "Entrega en 24-72 horas",
            "text": "Después de la compra, los leads empiezan a llegar a tu WhatsApp o a la plataforma que uses en menos de 3 días hábiles."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "refresh",
            "title": "Reposición de leads malos",
            "text": "Si un lead viene mal de origen (número falso, persona equivocada) lo revisamos caso por caso y lo reponemos."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "shield",
            "title": "Soporte que contesta",
            "text": "No te dejamos colgado después de cobrar. Si tienes una duda dos semanas después, te seguimos respondiendo."
          }
        }
      ]
    }
  ]
}
{% endschema %}
