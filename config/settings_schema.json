[
  {
    "name": "theme_info",
    "theme_name": "Tienda de Leads",
    "theme_version": "1.0.0",
    "theme_author": "Just Build It Now",
    "theme_documentation_url": "https://leads.justbuilditnow.com",
    "theme_support_url": "https://leads.justbuilditnow.com"
  },
  {
    "name": "Marca",
    "settings": [
      {
        "type": "text",
        "id": "brand_name",
        "label": "Nombre de la marca",
        "default": "Tienda de Leads"
      },
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Tagline (debajo del logo en el footer)",
        "default": "Conecta Con Prospectos Listos Para Actuar"
      },
      {
        "type": "image_picker",
        "id": "brand_logo",
        "label": "Logo (header)"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "min": 80,
        "max": 240,
        "step": 10,
        "unit": "px",
        "label": "Ancho máximo del logo",
        "default": 140
      }
    ]
  },
  {
    "name": "Colores",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Fondo principal",
        "default": "#0d0d0d"
      },
      {
        "type": "color",
        "id": "color_bg_soft",
        "label": "Fondo suave (secciones alternas)",
        "default": "#171717"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Texto principal",
        "default": "#f0e8d8"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Texto secundario",
        "default": "#a8a08c"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Acento (botones, links — dorado)",
        "default": "#c8a663"
      },
      {
        "type": "color",
        "id": "color_accent_hover",
        "label": "Acento hover (dorado claro)",
        "default": "#d4b56e"
      },
      {
        "type": "color",
        "id": "color_badge_sale",
        "label": "Badge de oferta (dorado brillante)",
        "default": "#d4af37"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Bordes",
        "default": "#2a2a2a"
      }
    ]
  },
  {
    "name": "Tipografía",
    "settings": [
      {
        "type": "select",
        "id": "font_family",
        "label": "Familia tipográfica",
        "options": [
          { "value": "system", "label": "System (rápido, nativo)" },
          { "value": "inter", "label": "Inter (Google Fonts)" },
          { "value": "poppins", "label": "Poppins (Google Fonts)" }
        ],
        "default": "system"
      },
      {
        "type": "range",
        "id": "base_font_size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "label": "Tamaño base de fuente",
        "default": 16
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "unit": "px",
        "label": "Ancho máximo de contenido",
        "default": 1200
      }
    ]
  },
  {
    "name": "Contacto / Redes",
    "settings": [
      {
        "type": "url",
        "id": "whatsapp_url",
        "label": "URL de WhatsApp (CTA flotante y footer)"
      },
      {
        "type": "text",
        "id": "contact_email",
        "label": "Email de contacto",
        "default": "hola@justbuilditnow.com"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook URL"
      }
    ]
  },
  {
    "name": "Scripts externos",
    "settings": [
      {
        "type": "paragraph",
        "content": "Scripts de terceros que se inyectan antes del cierre del </body>. Útil para chat widgets, analytics o pixels."
      },
      {
        "type": "textarea",
        "id": "chat_widget_script",
        "label": "Chat widget (GHL / Tidio / Intercom)",
        "info": "Pegá el script tag completo. Se carga después de toda la página."
      },
      {
        "type": "textarea",
        "id": "analytics_script",
        "label": "Analytics / Pixel (opcional)",
        "info": "Google Analytics, Meta Pixel, etc."
      },
      {
        "type": "checkbox",
        "id": "hide_whatsapp_fab",
        "label": "Ocultar botón flotante de WhatsApp",
        "info": "Activá esto si usás un chat widget que tiene su propio botón.",
        "default": false
      }
    ]
  }
]
