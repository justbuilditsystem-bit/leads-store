{% layout 'theme' %}

<section class="jb-section jb-404">
  <div class="jb-container jb-container--narrow jb-404__inner">
    <span class="jb-404__code">404</span>
    <h1 class="jb-404__title">Esta página no existe.</h1>
    <p class="jb-404__text">El link puede estar roto o la página fue removida. Vuelve al inicio y seguimos.</p>
    <a href="{{ routes.root_url }}" class="jb-btn jb-btn--primary jb-btn--lg">Volver al inicio</a>
  </div>
</section>
